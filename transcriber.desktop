[Desktop Entry]
Type=Application
Name=Transcriber
Comment=Voice-to-text transcription application using Whisper
Exec=transcriber
Icon=redmic
Terminal=false
Categories=AudioVideo;Audio;
Keywords=voice;transcription;speech;whisper;dictation;

# GNOME Dock / Dash integration
# DBusActivatable tells GNOME Shell that the app is already running when
# the D-Bus name is owned, so clicking the dock icon activates the existing
# instance instead of launching a new one.
DBusActivatable=true
StartupNotify=false
StartupWMClass=transcriber
